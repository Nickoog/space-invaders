# .agents
# Source of truth for all hooks and slash commands in this project.
#
# Hooks are activated in:     .claude/settings.json
# Slash commands live in:     .claude/commands/*.md
#
# Workflow: edit definitions here first, then generate the real files from this spec.

hooks:

  - name: globalAlpha guard
    trigger: post-edit
    match: src/renderer.js
    description: >
      Warns if ctx.globalAlpha is assigned a value other than 1
      without being reset to 1 in the same function.
      A forgotten reset corrupts all subsequent rendering silently.
    script: |
      grep -n "globalAlpha" src/renderer.js

  - name: ROW sync check
    trigger: post-edit
    match: src/constants.js
    description: >
      Warns if ROW_POINTS or ROW_COLORS length diverges from ENEMY_ROWS.
      These three values are implicitly coupled and must stay in sync.
    script: |
      node -e "
        const fs  = require('fs');
        const src = fs.readFileSync('src/constants.js', 'utf8');
        const rows = src.match(/ENEMY_ROWS\s*=\s*(\d+)/)?.[1];
        const pts  = (src.match(/ROW_POINTS\s*=\s*\[([^\]]+)\]/)?.[1]?.split(',') ?? []).length;
        const cols = (src.match(/ROW_COLORS\s*=\s*\[([^\]]+)\]/)?.[1]?.split(',') ?? []).length;
        if (rows && (pts != rows || cols != rows))
          console.warn('WARNING: ROW_POINTS(' + pts + ') or ROW_COLORS(' + cols + ') length does not match ENEMY_ROWS=' + rows);
        else
          console.log('OK: ROW_POINTS, ROW_COLORS and ENEMY_ROWS are in sync (' + rows + ' entries).');
      "

  - name: multi-file confirmation reminder
    trigger: pre-tool-use
    match: Write|Edit
    description: >
      Reminds the agent to present a full plan and wait for user confirmation
      before modifying more than one file in a session.
    note: >
      This hook is enforced as a behavioural rule in AGENTS.md rather than a script,
      because Claude Code pre-tool-use hooks cannot track cross-call session state.
      Keep this entry here as documentation of the intent.

commands:

  - name: cold-start
    description: >
      Instructions to clear the sprite cache and verify cold loading of Pokémon sprites.
    content: |
      Run this in the browser console to clear the sprite cache and force a full reload:

        sessionStorage.clear(); location.reload();

      Then verify:
        - Loading screen appears with the progress bar
        - All 55 Pokémon sprites load (or gracefully fall back to colored circles)
        - No mixed-content errors in the console (http:// URLs should be upgraded to https://)
        - After loading, the menu screen appears and the game is playable

  - name: check-magic
    description: >
      List numeric literals found in src/ that are not defined in constants.js.
      Helps surface magic numbers before a refactor or PR.
    content: |
      Search for numeric literals across src/ (excluding constants.js):

        grep -rn --include="*.js" '[^a-zA-Z_][0-9]\+' src/ | grep -v "src/constants.js"

      Known intentional magic numbers (documented in AGENTS.md — do not blindly move these):
        700, 120   → PokemonGrid.js  difficulty formula base values
        0.85       → PokemonGrid.js  grid acceleration coefficient
        2000       → Game.js         player invincibility duration (ms)
        1500       → Game.js         delay before "press Enter to replay" (ms)
        100        → renderer.js     invincibility blink interval (ms)
        500        → screens.js      menu text blink interval (ms)

  - name: diff-safe
    description: >
      Pre-commit safety checklist tailored to this project.
      Compensates for the total absence of automated tests.
    content: |
      Run the following checks before committing:

      1. List all modified files:
           git diff --name-only

      2. Verify globalAlpha resets in renderer.js:
           grep -n "globalAlpha" src/renderer.js
         Every assignment to a value ≠ 1 must be followed by `ctx.globalAlpha = 1;`

      3. Check ROW_POINTS / ROW_COLORS / ENEMY_ROWS are in sync:
           grep -E "ENEMY_ROWS|ROW_POINTS|ROW_COLORS" src/constants.js
         All three must have the same number of entries.

      4. Check for new inline numeric literals outside constants.js:
           git diff src/ | grep "^+" | grep -E "[^A-Z_][0-9]{2,}" | grep -v constants.js
         Any hit should be reviewed — add to constants.js or document in AGENTS.md.

      5. Manual gameplay verification (no automated tests exist):
           - Pokéball vs Pokémon collision
           - Enemy bullet vs player + shields collision
           - Level transition (all caught → next level starts)
           - Game over (grid reaches player line)
